generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String?  @unique
  email        String?  @unique
  passwordHash String
  role         String   @default("client")
  avatar       String?
  createdAt    DateTime @default(now())

  bookings Booking[]
}

model Training {
  id        Int      @id @default(autoincrement())
  title     String
  trainer   String
  day       String
  time      String
  hall      String
  capacity  Int      @default(20)
  createdAt DateTime @default(now())

  bookings Booking[]
}

model Booking {
  id         Int      @id @default(autoincrement())
  userId     Int
  trainingId Int
  status     String   @default("active")
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  training Training @relation(fields: [trainingId], references: [id])

  @@unique([userId, trainingId])
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  image     String?
  createdAt DateTime @default(now())
}

model FAQ {
  id       Int    @id @default(autoincrement())
  question String
  answer   String
}
